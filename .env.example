BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DASHBOARD_PORT=3000
DATA_ROOT=./data
WEBCAM_INDEX=0
FAMS_HOST=
FAMS_USER=
FAMS_REMOTE_PATH=/data/fams/archive

# Optional: SSH key path for FAMS upload workflow.
FAMS_SSH_KEY_PATH=

# Optional: Use PostgreSQL by setting DATABASE_URL and enabling profile "database" in docker compose.
DATABASE_URL=
POSTGRES_DB=imu_collector
POSTGRES_USER=imu_collector
POSTGRES_PASSWORD=imu_collector
POSTGRES_PORT=5432

# Backup settings (Phase 15 hardening)
BACKUP_SOURCE_DIR=./data
BACKUP_OUTPUT_DIR=./backups
BACKUP_RETENTION_DAYS=14
