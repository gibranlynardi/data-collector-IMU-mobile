CLOCK_SYNC_GOOD_OFFSET_MS=30
CLOCK_SYNC_WARN_OFFSET_MS=75
CLOCK_SYNC_GOOD_LATENCY_MS=60
CLOCK_SYNC_WARN_LATENCY_MS=120
CLOCK_SYNC_BLOCK_ON_BAD=true
STOP_COMMAND_ACK_TIMEOUT_SECONDS=2.0
FAMS_HOST=
FAMS_USER=
