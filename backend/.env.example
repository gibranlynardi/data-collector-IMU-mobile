BACKEND_HOST=0.0.0.0
BACKEND_REST_PORT=8000
BACKEND_WS_PORT=8000  # must match REST port; both served on same port
OPERATOR_API_TOKEN=
DEVICE_ENROLLMENT_TOKEN=
CORS_ALLOW_ORIGINS=*
DATA_ROOT=./data
DATABASE_URL=
WEBCAM_INDEX=0
WEBCAM_PATH=
WEBCAM_MIN_FPS=15
WEBCAM_TARGET_FPS=30
WEBCAM_TARGET_WIDTH=1280
WEBCAM_TARGET_HEIGHT=720
WEBCAM_CODEC=mp4v
WEBCAM_MIN_FREE_BYTES=1000000000
FFMPEG_FALLBACK_ENABLED=true
FFMPEG_EXECUTABLE=ffmpeg
FFMPEG_CAMERA_INPUT=
FFMPEG_CAMERA_FORMAT=dshow
VIDEO_DEFACE_ENABLED=true
VIDEO_DEFACE_EXECUTABLE=deface
VIDEO_DEFACE_REPLACEWITH=blur
VIDEO_DEFACE_KEEP_AUDIO=false
VIDEO_DEFACE_BACKEND=auto
VIDEO_DEFACE_BLUR_KERNEL=51
VIDEO_DEFACE_SCALE_FACTOR=1.1
VIDEO_DEFACE_MIN_NEIGHBORS=5
