# Master Backend Environment Configuration
# Copy to .env and fill in values before running

# Storage paths
SSD_PATH=D:/IMU_Data_SSD
RESCUE_PATH=D:/IMU_Data_Rescue

# Network
BIND_HOST=0.0.0.0
PORT=8000
LAN_SUBNET=192.168.1.0/24

# Session config
FSYNC_INTERVAL_SEC=5
MAX_CONCURRENT_DEVICES=8

# FAMS SSH (Phase 7 — leave blank for now)
FAMS_HOST=
FAMS_PORT=22
FAMS_USER=
FAMS_KEY_PATH=
FAMS_REMOTE_DIR=
